# Cloudflare Workers 应用配置
# 复制此文件为 wrangler.toml 并填入你的配置

name = "missav-bot"
main = "src/index.js"
compatibility_date = "2024-01-01"

# KV 命名空间绑定
[[kv_namespaces]]
binding = "MISSAV_DATA"
id = "your-kv-namespace-id"
preview_id = "your-preview-kv-namespace-id"

[[kv_namespaces]]
binding = "SUBSCRIPTIONS"
id = "your-subscriptions-namespace-id"
preview_id = "your-preview-subscriptions-namespace-id"

[[kv_namespaces]]
binding = "PUSH_RECORDS"
id = "your-push-records-namespace-id"
preview_id = "your-preview-push-records-namespace-id"

# 定时任务触发器
[[triggers]]
crons = ["*/15 * * * *"]  # 每15分钟执行一次（双爬虫）

# 路由规则
# [[routes]]
# pattern = "your-domain.workers.dev/*"
# zone_name = "your-domain.com"

[vars]
# 环境变量配置
TELEGRAM_API_URL = "https://api.telegram.org/bot"
MISSAV_BASE_URL = "https://missav.ai"
JAVNJINJA_BASE_URL = "https://javninja.com"

# 爬虫开关（默认都启用）
MISSAV_ENABLED = true
JAVNJINJA_ENABLED = true

# 爬虫配置
CRAWLER_ENABLED = true
MISSAV_CRAWL_INTERVAL = "900000"  # 15分钟
CRAWLER_INITIAL_PAGES = 2

[env]
# 生产环境变量
# TELEGRAM_BOT_TOKEN = "your-bot-token"
# TELEGRAM_BOT_USERNAME = "YourBotUsername"

# JAVNinja 配置（可选）
# JAVNJINJA_BASE_URL = "https://javninja.com"
# JAVNJINJA_ENABLED = true

# MissAV 配置（可选）
# MISSAV_BASE_URL = "https://missav.ai"
# MISSAV_ENABLED = true
